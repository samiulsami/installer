{{- $alertname := or .GroupLabels.alertname .CommonLabels.alertname "Alertmanager Notification" -}}
{{- $kind := or .GroupLabels.k8s_kind .CommonLabels.k8s_kind "" -}}
{{- $name := or .GroupLabels.k8s_resource .CommonLabels.k8s_resource "" -}}
{{- $namespace := or .GroupLabels.namespace .CommonLabels.namespace .CommonLabels.app_namespace "" -}}
{{- $job := or .GroupLabels.job .CommonLabels.job "" -}}
{{- $cluster := or .GroupLabels.cluster .CommonLabels.cluster "" -}}
{{- $clusterUID := printf "%.8s" (or .GroupLabels.cluster_uid .CommonLabels.cluster_uid "") -}}
{{- $resource := "" -}}
{{- if and $namespace $name -}}
  {{- $resource = printf "%s/%s" $namespace $name -}}
{{- else if $namespace -}}
  {{- $resource = $namespace -}}
{{- else if $name -}}
  {{- $resource = $name -}}
{{- end -}}
{{- if or $cluster $clusterUID -}}[{{ if $cluster }}{{ $cluster }}{{ else }}unknown{{ end }}{{ if $clusterUID }}/{{ $clusterUID }}{{ end }}] {{ end -}}
[{{- if gt (len .Alerts.Firing) 0 -}}FIRING:{{ len .Alerts.Firing }}{{- end -}}
{{- if and (gt (len .Alerts.Firing) 0) (gt (len .Alerts.Resolved) 0) -}} | {{- end -}}
{{- if gt (len .Alerts.Resolved) 0 -}}RESOLVED:{{ len .Alerts.Resolved }}{{- end -}}] {{ $alertname -}}
{{- if $kind }} - {{ $kind }}{{ end -}}
{{- if $resource }} - {{ $resource }}{{ end -}}
{{- if $job }} [Via {{ $job }}]{{ end -}}
